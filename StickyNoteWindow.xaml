<Window x:Class="StickyNotes.StickyNoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        Width="320" Height="280"
        MinWidth="150" MinHeight="120"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        PreviewMouseMove="Window_PreviewMouseMove"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown"
        PreviewMouseLeftButtonUp="Window_PreviewMouseLeftButtonUp"
        Loaded="Window_Loaded">

    <!-- 外层 Border: 圆角 + 阴影 + 暗黄背景 -->
    <Border x:Name="OuterBorder"
            CornerRadius="8"
            Background="#E8C547"
            BorderBrush="#C9A820"
            BorderThickness="1">

        <!-- 注意: DropShadowEffect 与 AllowsTransparency=True 配合时可能导致渲染问题，
             此处先不加阴影，确保稳定后再评估 -->

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题条 -->
            <Border x:Name="TitleBarBorder"
                    Grid.Row="0"
                    Background="#C9A820"
                    CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="📝 便签"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#5C4A00"
                               IsHitTestVisible="False"/>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,2,0">
                        <Button x:Name="PinButton"
                                Content="📌"
                                Style="{StaticResource TitleBarButton}"
                                ToolTip="钉住"
                                Width="28" Height="22"
                                FontSize="11"
                                Click="PinButton_Click"/>
                        <Button x:Name="CollapseButton"
                                Content="─"
                                Style="{StaticResource TitleBarButton}"
                                ToolTip="折叠"
                                Width="28" Height="22"
                                FontSize="12"
                                FontWeight="Bold"
                                Padding="0,-2,0,0"
                                Click="CollapseButton_Click"/>
                        <Button x:Name="ColorButton"
                                Content="🎨"
                                Style="{StaticResource TitleBarButton}"
                                ToolTip="改颜色"
                                Width="28" Height="22"
                                FontSize="11"
                                Click="ColorButton_Click"/>
                        <Button x:Name="DeleteButton"
                                Content="✕"
                                Style="{StaticResource TitleBarButton}"
                                ToolTip="删除"
                                Width="28" Height="22"
                                FontSize="12"
                                Click="DeleteButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 颜色选择面板 (Popup) -->
            <Popup x:Name="ColorPopup"
                   PlacementTarget="{Binding ElementName=ColorButton}"
                   Placement="Bottom"
                   StaysOpen="False"
                   AllowsTransparency="True">
                <Border Background="White"
                        BorderBrush="#CCC"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="3">
                    <UniformGrid Columns="3" Rows="2">
                        <Rectangle Width="24" Height="24" Fill="#E8C547"
                                   Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#E8C547;#C9A820" Margin="2" RadiusX="3" RadiusY="3"/>
                        <Rectangle Width="24" Height="24" Fill="#A5D6A7"
                                   Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#A5D6A7;#81C784" Margin="2" RadiusX="3" RadiusY="3"/>
                        <Rectangle Width="24" Height="24" Fill="#90CAF9"
                                   Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#90CAF9;#64B5F6" Margin="2" RadiusX="3" RadiusY="3"/>
                        <Rectangle Width="24" Height="24" Fill="#F48FB1"
                                   Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#F48FB1;#F06292" Margin="2" RadiusX="3" RadiusY="3"/>
                        <Rectangle Width="24" Height="24" Fill="#CE93D8"
                                   Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#CE93D8;#BA68C8" Margin="2" RadiusX="3" RadiusY="3"/>
                        <Rectangle Width="24" Height="24" Fill="#FFCC80"
                                   Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#FFCC80;#FFB74D" Margin="2" RadiusX="3" RadiusY="3"/>
                    </UniformGrid>
                </Border>
            </Popup>

            <!-- 正文编辑区 -->
            <RichTextBox Grid.Row="1"
                         x:Name="ContentBox"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="#2D2D2D"
                         Margin="10,6,10,10"
                         FontSize="14"
                         FontFamily="Microsoft YaHei"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         />
        </Grid>
    </Border>
</Window>
