<Window x:Class="StickyNotes.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="使用说明 — 桌面便签"
        Width="480" Height="600"
        MinWidth="380" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Margin" Value="0,14,0,4"/>
        </Style>
        <Style x:Key="BulletItem" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#444"/>
            <Setter Property="Margin" Value="16,2,0,2"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#FAFAFA">
        <StackPanel Margin="24,16,24,24">

            <!-- 标题 -->
            <TextBlock Text="桌面便签 · 使用说明"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#2D2D2D"
                       Margin="0,0,0,12"/>

            <!-- 新建便签 -->
            <TextBlock Text="【新建便签】" Style="{StaticResource SectionHeader}"/>
            <TextBlock Text="· 左键单击右下角托盘图标，新建一张便签" Style="{StaticResource BulletItem}"/>
            <TextBlock Text="· 或右键托盘图标 →「新建便签」" Style="{StaticResource BulletItem}"/>
            <TextBlock Text="· 每张新便签会自动错开位置，不会完全重叠" Style="{StaticResource BulletItem}"/>

            <!-- 写字 / 富文本 -->
            <TextBlock Text="【写字 / 富文本】" Style="{StaticResource SectionHeader}"/>
            <TextBlock Text="· 直接在便签正文区打字，支持中英文、回车换行" Style="{StaticResource BulletItem}"/>
            <TextBlock Text="· 选中文字后：Ctrl+B 加粗、Ctrl+I 斜体、Ctrl+U 下划线" Style="{StaticResource BulletItem}"/>
            <TextBlock Text="· 这些快捷键是开关，有格式时再按一次即可取消" Style="{StaticResource BulletItem}"/>
            <TextBlock Text="· 打字会延续光标当前格式，想打普通字就先按对应快捷键关掉格式（与 Word 一致）" Style="{StaticResource BulletItem}"/>

            <!-- 移动便签 -->
            <TextBlock Text="【移动便签】" Style="{StaticResource SectionHeader}"/>
            <TextBlock Text="· 按住顶部标题条中间区域拖动，即可移动整张便签" Style="{StaticResource BulletItem}"/>

            <!-- 改变大小 -->
            <TextBlock Text="【改变大小】" Style="{StaticResource SectionHeader}"/>
            <TextBlock Text="· 把鼠标移到便签四条边或四个角，光标变箭头后拖动即可缩放" Style="{StaticResource BulletItem}"/>
            <TextBlock Text="· 有最小尺寸限制（150×120），缩不到更小" Style="{StaticResource BulletItem}"/>

            <!-- 标题条按钮 -->
            <TextBlock Text="【标题条按钮】（从左到右）" Style="{StaticResource SectionHeader}"/>
            <TextBlock Text="· 📌 钉住：点击让便签置顶，浮在所有程序之上；再点取消" Style="{StaticResource BulletItem}"/>
            <TextBlock Text="· ─ 折叠：点击只保留标题条窄条，再点恢复，内容不丢" Style="{StaticResource BulletItem}"/>
            <TextBlock Text="· 🎨 颜色：点击弹出六种颜色（黄/绿/蓝/粉/紫/橙），每张可独立设色" Style="{StaticResource BulletItem}"/>
            <TextBlock Text="· ✕ 删除：删掉这一张便签，不影响其他便签" Style="{StaticResource BulletItem}"/>

            <!-- 自动保存 -->
            <TextBlock Text="【自动保存】" Style="{StaticResource SectionHeader}"/>
            <TextBlock Text="· 所有便签的内容、位置、大小、颜色、钉住/折叠状态都会自动保存" Style="{StaticResource BulletItem}"/>
            <TextBlock Text="· 关闭程序或重启电脑后重新打开会原样恢复" Style="{StaticResource BulletItem}"/>

            <!-- 退出程序 -->
            <TextBlock Text="【退出程序】" Style="{StaticResource SectionHeader}"/>
            <TextBlock Text="· 右键托盘图标 →「退出」关闭整个程序" Style="{StaticResource BulletItem}"/>
            <TextBlock Text="· 删光所有便签不会退出，托盘图标仍在，可继续新建" Style="{StaticResource BulletItem}"/>

            <!-- 开机自启 -->
            <TextBlock Text="【开机自启】" Style="{StaticResource SectionHeader}"/>
            <TextBlock Text="· 右键托盘图标 →「开机自启」，前面打钩即开启" Style="{StaticResource BulletItem}"/>
            <TextBlock Text="· 开启后每次开机便签程序会自动启动，再点一次取消" Style="{StaticResource BulletItem}"/>
            <TextBlock Text="· 注意：开启自启后请勿移动程序所在文件夹，否则需在新位置重新打钩一次" Style="{StaticResource BulletItem}"/>

        </StackPanel>
    </ScrollViewer>
</Window>
